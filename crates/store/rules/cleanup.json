{
  "_meta": {
    "pack": "cleanup",
    "version": 1,
    "description": "Disk/cache/docker cleanup signal rules."
  },
  "rules": [
    {
      "id": "cleanup.disk-usage",
      "version": 1,
      "kind": "regex",
      "status": "active",
      "severity": "info",
      "event_kind": "disk_usage",
      "stream": "stdout",
      "description": "df -h filesystem usage row.",
      "pattern": "(?P<fs>/dev/\\S+|tmpfs|overlay|none)\\s+(?P<size>\\S+)\\s+(?P<used>\\S+)\\s+(?P<avail>\\S+)\\s+(?P<pct>\\d+%)\\s+(?P<mount>/\\S*)",
      "captures": ["fs", "size", "used", "avail", "pct", "mount"],
      "summary_template": "disk ${mount}: ${used}/${size} (${pct} used), ${avail} free",
      "tags": ["cleanup", "disk"],
      "rate_limit_per_min": 60,
      "redact": [],
      "context_hint": { "before_lines": 0, "after_lines": 0 }
    },
    {
      "id": "cleanup.dir-size",
      "version": 1,
      "kind": "regex",
      "status": "active",
      "severity": "info",
      "event_kind": "dir_size",
      "stream": "stdout",
      "description": "du -sh style size + path row.",
      "pattern": "^(?P<size>[0-9.]+[KMGT]?)\\s+(?P<path>\\S.*)$",
      "captures": ["size", "path"],
      "summary_template": "size ${size}: ${path}",
      "tags": ["cleanup", "disk"],
      "rate_limit_per_min": 60,
      "redact": [],
      "context_hint": { "before_lines": 0, "after_lines": 0 }
    },
    {
      "id": "cleanup.docker-usage",
      "version": 1,
      "kind": "regex",
      "status": "active",
      "severity": "info",
      "event_kind": "docker_usage",
      "stream": "stdout",
      "description": "docker system df reclaimable summary row.",
      "pattern": "^(?P<type>Images|Containers|Local Volumes|Build Cache)\\s+(?P<total>\\d+)\\s+(?P<active>\\d+)\\s+(?P<size>[0-9.]+\\s*[A-Za-z]+)\\s+(?P<reclaimable>[0-9.]+\\s*[A-Za-z]+)",
      "captures": ["type", "total", "active", "size", "reclaimable"],
      "summary_template": "docker ${type}: size ${size}, reclaimable ${reclaimable}",
      "tags": ["cleanup", "docker"],
      "rate_limit_per_min": 30,
      "redact": [],
      "context_hint": { "before_lines": 0, "after_lines": 0 }
    },
    {
      "id": "cleanup.fstrim",
      "version": 1,
      "kind": "regex",
      "status": "active",
      "severity": "info",
      "event_kind": "fstrim",
      "stream": "stdout",
      "description": "fstrim -v trimmed-bytes report line.",
      "pattern": "^(?P<mount>/\\S*):\\s+(?P<human>[0-9.]+\\s*[KMGT]?i?B)\\s+\\((?P<bytes>\\d+)\\s+bytes\\)\\s+trimmed",
      "captures": ["mount", "human", "bytes"],
      "summary_template": "trimmed ${mount}: ${human}",
      "tags": ["cleanup", "fstrim"],
      "rate_limit_per_min": 30,
      "redact": [],
      "context_hint": { "before_lines": 0, "after_lines": 0 }
    },
    {
      "id": "cleanup.space-reclaimed",
      "version": 1,
      "kind": "regex",
      "status": "active",
      "severity": "info",
      "event_kind": "space_reclaimed",
      "stream": "stdout",
      "description": "Aggregate reclaimed/freed/trimmed space line (docker/apt/cargo).",
      "pattern": "(?:Total reclaimed space|freed|trimmed|Freed):?\\s+(?P<amount>[0-9.]+\\s*[KMGT]?i?B)",
      "captures": ["amount"],
      "summary_template": "reclaimed ${amount}",
      "tags": ["cleanup"],
      "rate_limit_per_min": 30,
      "redact": [],
      "context_hint": { "before_lines": 0, "after_lines": 0 }
    }
  ]
}
