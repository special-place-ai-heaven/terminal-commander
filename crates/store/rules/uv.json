{
  "_meta": {
    "pack": "uv",
    "version": 1,
    "description": "uv (Astral Python package manager) error rules."
  },
  "rules": [
    {
      "id": "uv.no-solution",
      "version": 1,
      "kind": "keyword",
      "status": "draft",
      "severity": "high",
      "event_kind": "dependency_conflict",
      "stream": "stderr",
      "description": "uv could not resolve dependencies.",
      "keywords": ["No solution found when resolving dependencies"],
      "captures": [],
      "summary_template": "uv: no dependency solution",
      "tags": ["packaging", "python", "uv"],
      "rate_limit_per_min": 12,
      "redact": [],
      "context_hint": { "before_lines": 0, "after_lines": 2 }
    },
    {
      "id": "uv.error-line",
      "version": 1,
      "kind": "regex",
      "status": "draft",
      "severity": "high",
      "event_kind": "command_failed",
      "stream": "stderr",
      "description": "A uv error line.",
      "pattern": "^error: (?P<message>.+)$",
      "captures": ["message"],
      "summary_template": "uv error: ${message}",
      "tags": ["packaging", "python", "uv"],
      "rate_limit_per_min": 30,
      "redact": [],
      "context_hint": { "before_lines": 0, "after_lines": 1 }
    },
    {
      "id": "uv.package-not-found",
      "version": 1,
      "kind": "regex",
      "status": "draft",
      "severity": "high",
      "event_kind": "missing_package",
      "stream": "stderr",
      "description": "uv could not find a package.",
      "pattern": "Package `(?P<package>[^`]+)` was not found",
      "captures": ["package"],
      "summary_template": "uv: package not found ${package}",
      "tags": ["packaging", "python", "uv"],
      "rate_limit_per_min": 30,
      "redact": [],
      "context_hint": { "before_lines": 0, "after_lines": 1 }
    }
  ]
}
