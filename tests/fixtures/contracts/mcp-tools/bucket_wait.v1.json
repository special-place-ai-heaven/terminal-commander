            "job_id": "job_018f0000000000000000000000000001"
          },
          "pointer": {
            "frame_id": "frm_018f0000000000000000000000000240",
            "line": 7,
            "stream": "stderr",
            "context_available": true
          }
        }
      ]
    },
    "heartbeat": {
