{
  "_meta": {
    "fixture_id": "contracts/mcp-tools/bucket_wait.v1.json",
    "schema_anchor": "TC05/mcp-tools/bucket_wait-v1",
    "status": "live",
    "consumed_by": [
      "TC45"
    ],
    "note": "Daemon-backed wait tool. Response carries either non-empty events or heartbeat=true with empty events. Raw stdout/stderr text is never a success shape. TB-8: the cursor param description teaches the pagination protocol (pass 0 on the first call, then the next_cursor from the previous response) and bucket_id carries a bkt_<32hex> format note so the first call succeeds. US4/FR-030: the optional compact flag (default false) projects each returned signal to the load-bearing field set {summary, stream, seq, severity} and echoes compact:true; the full records stay re-fetchable by re-reading the same cursor with compact omitted, and compact never changes which events match."
  },
  "tool": "bucket_wait",
  "request_example": {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "tools/call",
    "params": {
      "name": "bucket_wait",
      "arguments": {
        "bucket_id": "bkt_018f0000000000000000000000000001",
        "cursor": 2,
        "severity_min": "medium",
        "kind_filter": null,
        "limit": 100,
        "timeout_ms": 30000
      }
    }
  },
  "response_examples": {
    "with_events": {
      "bucket_id": "bkt_018f0000000000000000000000000001",
      "cursor_in": 2,
      "next_cursor": 3,
      "heartbeat": false,
      "dropped_count": 0,
      "events": [
        {
          "event_id": "evt_018f0000000000000000000000000002",
          "bucket_id": "bkt_018f0000000000000000000000000001",
          "seq": 3,
          "timestamp": "2026-05-25T17:45:03Z",
          "severity": "high",
          "kind": "compile_error",
          "summary": "rustc E0432: unresolved import `crate::missing_module`",
          "captures": {
            "code": "E0432"
          },
