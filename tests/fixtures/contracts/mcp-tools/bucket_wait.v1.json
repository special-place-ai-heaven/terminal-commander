  },
  "invariants": [
    "bucket_id and cursor are required",
    "cursor description teaches pass-0-then-next_cursor pagination (TB-8)",
    "bucket_id description carries the bkt_ opaque-id format note (TB-8)",
    "heartbeat=true implies events=[]",
    "heartbeat=false implies events is non-empty",
    "success payload never contains raw stdout or stderr dumps",
    "US4/FR-030: compact:true projects signals to {summary,stream,seq,severity} and echoes compact:true; compact omitted is byte-identical and full records stay re-fetchable by the same cursor"
  ]
