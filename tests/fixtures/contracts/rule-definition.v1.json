{
  "_meta": {
    "fixture_id": "contracts/rule-definition.v1.json",
    "schema_anchor": "TC05/rule-v1",
    "status": "live-canonical",
    "required": ["id", "version", "kind", "severity", "event_kind", "summary_template"],
    "optional": ["status", "description", "stream", "pattern", "keywords", "captures", "tags", "rate_limit_per_min", "redact", "examples", "context_hint"]
  },
  "id": "apt-missing-package",
  "version": 1,
  "kind": "regex",
  "severity": "high",
  "event_kind": "missing_package",
  "stream": "stderr",
  "description": "Match APT 'Unable to locate package' lines and capture the package name.",
  "pattern": "^E: Unable to locate package (?P<package>[A-Za-z0-9._+-]+)$",
  "captures": ["package"],
  "summary_template": "APT could not locate package ${package}",
  "tags": ["packaging", "apt"],
  "rate_limit_per_min": 30,
  "redact": [],
  "context_hint": { "before_lines": 3, "after_lines": 1 },
  "examples": [
    { "input": "E: Unable to locate package libssl-dev",
      "expect": { "kind": "missing_package", "captures": { "package": "libssl-dev" } } },
    { "input": "E: Couldn't find any package by glob 'libssl-dev'",
      "expect": { "match": false } }
  ]
}
